{
  "name": "warframe-tracker",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "db:generate": "pnpm --filter api db:generate",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:seed": "pnpm --filter api db:seed",
    "test:sync": "pnpm --filter web exec svelte-kit sync",
    "test": "pnpm test:sync && vitest run",
    "test:watch": "pnpm test:sync && vitest",
    "test:coverage": "pnpm test:sync && vitest run --coverage"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.0.0",
    "vitest": "^4.0.0"
  }
}
