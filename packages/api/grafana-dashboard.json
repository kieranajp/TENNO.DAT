{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "id": null,
  "uid": "tenno-api",
  "title": "TENNO.DAT API",
  "tags": ["tenno", "api"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "title": "",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },

    {
      "title": "Request Rate",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "targets": [{
        "expr": "sum(rate(http_requests_total{app=\"tenno-api\"}[$__rate_interval]))",
        "legendFormat": "req/s"
      }]
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } } },
      "targets": [{
        "expr": "sum(rate(http_requests_total{app=\"tenno-api\", ok=\"false\"}[$__rate_interval])) / sum(rate(http_requests_total{app=\"tenno-api\"}[$__rate_interval]))",
        "legendFormat": "error %"
      }]
    },
    {
      "title": "p50 / p95 / p99 Latency",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 8, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 2 }] } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{app=\"tenno-api\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{app=\"tenno-api\"}[$__rate_interval])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{app=\"tenno-api\"}[$__rate_interval])))", "legendFormat": "p99" }
      ]
    },
    {
      "title": "Syncs Completed",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{
        "expr": "increase(tenno_sync_completed_total{app=\"tenno-api\"}[$__rate_interval])",
        "legendFormat": "syncs"
      }]
    },
    {
      "title": "Auth Attempts",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "purple", "value": null }] } } },
      "targets": [{
        "expr": "increase(tenno_steam_auth_attempts_total{app=\"tenno-api\"}[$__rate_interval])",
        "legendFormat": "attempts"
      }]
    },

    {
      "title": "HTTP Traffic",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },

    {
      "title": "Request Rate by Route",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } } },
      "targets": [{
        "expr": "sum by (route, method) (rate(http_requests_total{app=\"tenno-api\", route!=\"/metrics\"}[$__rate_interval]))",
        "legendFormat": "{{method}} {{route}}"
      }]
    },
    {
      "title": "Latency by Route (p95)",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket{app=\"tenno-api\", route!=\"/metrics\"}[$__rate_interval])))",
        "legendFormat": "{{route}}"
      }]
    },
    {
      "title": "Error Responses by Route",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" }, "drawStyle": "bars" } } },
      "targets": [{
        "expr": "sum by (route, status) (rate(http_requests_total{app=\"tenno-api\", ok=\"false\"}[$__rate_interval]))",
        "legendFormat": "{{route}} ({{status}})"
      }]
    },
    {
      "title": "Request Duration Heatmap (all routes)",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 15 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{app=\"tenno-api\", route!=\"/metrics\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.90, sum by (le) (rate(http_request_duration_seconds_bucket{app=\"tenno-api\", route!=\"/metrics\"}[$__rate_interval])))", "legendFormat": "p90" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{app=\"tenno-api\", route!=\"/metrics\"}[$__rate_interval])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{app=\"tenno-api\", route!=\"/metrics\"}[$__rate_interval])))", "legendFormat": "p99" }
      ]
    },

    {
      "title": "Profile Sync",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false,
      "panels": []
    },

    {
      "title": "DE Profile Fetch Duration",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le, platform) (rate(tenno_de_profile_fetch_duration_seconds_bucket{app=\"tenno-api\"}[$__rate_interval])))", "legendFormat": "p50 ({{platform}})" },
        { "expr": "histogram_quantile(0.95, sum by (le, platform) (rate(tenno_de_profile_fetch_duration_seconds_bucket{app=\"tenno-api\"}[$__rate_interval])))", "legendFormat": "p95 ({{platform}})" }
      ]
    },
    {
      "title": "DE Profile Fetch Errors",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 23 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 30, "drawStyle": "bars", "stacking": { "mode": "normal" } } } },
      "targets": [{
        "expr": "sum by (error_type) (increase(tenno_de_profile_fetch_errors_total{app=\"tenno-api\"}[$__rate_interval]))",
        "legendFormat": "{{error_type}}"
      }]
    },
    {
      "title": "Profile Payload Size",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
      "fieldConfig": { "defaults": { "unit": "decbytes", "custom": { "fillOpacity": 10 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(tenno_de_profile_payload_bytes_bucket{app=\"tenno-api\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(tenno_de_profile_payload_bytes_bucket{app=\"tenno-api\"}[$__rate_interval])))", "legendFormat": "p95" }
      ]
    },
    {
      "title": "Sync Items Matched vs Unmatched",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 31 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 20 } } },
      "targets": [
        { "expr": "tenno_sync_items_matched{app=\"tenno-api\"}", "legendFormat": "matched" },
        { "expr": "tenno_sync_items_unmatched{app=\"tenno-api\"}", "legendFormat": "unmatched" }
      ]
    },
    {
      "title": "Syncs Completed (rate)",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 31 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 20, "drawStyle": "bars" } } },
      "targets": [{
        "expr": "rate(tenno_sync_completed_total{app=\"tenno-api\"}[$__rate_interval])",
        "legendFormat": "syncs/s"
      }]
    },
    {
      "title": "Mastery Rank Distribution",
      "type": "bargauge",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 31 },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{
        "expr": "tenno_mastery_rank_bucket{app=\"tenno-api\"} - ignoring(le) tenno_mastery_rank_bucket{app=\"tenno-api\",le=\"0\"}",
        "legendFormat": "MR ≤{{le}}",
        "instant": true
      }]
    },

    {
      "title": "Authentication",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "collapsed": false,
      "panels": []
    },

    {
      "title": "Steam Auth Flow",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 15, "drawStyle": "bars", "stacking": { "mode": "normal" } } } },
      "targets": [
        { "expr": "increase(tenno_steam_auth_successes_total{app=\"tenno-api\", user_type=\"new\"}[$__rate_interval])", "legendFormat": "new users" },
        { "expr": "increase(tenno_steam_auth_successes_total{app=\"tenno-api\", user_type=\"returning\"}[$__rate_interval])", "legendFormat": "returning users" },
        { "expr": "increase(tenno_steam_auth_failures_total{app=\"tenno-api\"}[$__rate_interval])", "legendFormat": "failures" }
      ]
    },
    {
      "title": "Accounts",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 40 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "targets": [{
        "expr": "tenno_steam_auth_successes_total{app=\"tenno-api\", user_type=\"new\"} - tenno_account_deletions_total{app=\"tenno-api\"}",
        "legendFormat": "accounts"
      }]
    },
    {
      "title": "Deletions",
      "type": "stat",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 44 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "semi-dark-red", "value": null }] } } },
      "targets": [{
        "expr": "tenno_account_deletions_total{app=\"tenno-api\"}",
        "legendFormat": "deletions"
      }]
    },
    {
      "title": "Prime Parts Toggles",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 40 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 20, "drawStyle": "bars" }, "color": { "mode": "fixed", "fixedColor": "orange" } } },
      "targets": [{
        "expr": "rate(tenno_prime_parts_toggles_total{app=\"tenno-api\"}[$__rate_interval])",
        "legendFormat": "toggles/s"
      }]
    },

    {
      "title": "Database",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 48 },
      "collapsed": false,
      "panels": []
    },

    {
      "title": "DB Query Duration (p95 by method)",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 49 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le, method) (rate(tenno_db_query_duration_seconds_bucket{app=\"tenno-api\"}[$__rate_interval])))",
        "legendFormat": "{{method}}"
      }]
    },
    {
      "title": "DB Query Rate by Method",
      "type": "timeseries",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 49 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } } },
      "targets": [{
        "expr": "sum by (method) (rate(tenno_db_query_duration_seconds_count{app=\"tenno-api\"}[$__rate_interval]))",
        "legendFormat": "{{method}}"
      }]
    },
    {
      "title": "Slowest DB Queries (current p99)",
      "type": "table",
      "datasource": { "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 57 },
      "options": { "sortBy": [{ "displayName": "p99", "desc": true }] },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "method" }, "properties": [{ "id": "custom.width", "value": 300 }, { "id": "unit", "value": "string" }] }
        ]
      },
      "transformations": [
        { "id": "labelsToFields", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true } } }
      ],
      "targets": [{
        "expr": "histogram_quantile(0.99, sum by (le, method) (rate(tenno_db_query_duration_seconds_bucket{app=\"tenno-api\"}[5m])))",
        "legendFormat": "{{method}}",
        "instant": true,
        "format": "table"
      }]
    },

    {
      "title": "Node.js Runtime",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 65 },
      "collapsed": true,
      "panels": [
        {
          "title": "Heap Used",
          "type": "timeseries",
          "datasource": { "uid": "${datasource}" },
          "gridPos": { "h": 8, "w": 8, "x": 0, "y": 66 },
          "fieldConfig": { "defaults": { "unit": "decbytes", "custom": { "fillOpacity": 20 } } },
          "targets": [
            { "expr": "nodejs_heap_size_used_bytes{app=\"tenno-api\"}", "legendFormat": "used" },
            { "expr": "nodejs_heap_size_total_bytes{app=\"tenno-api\"}", "legendFormat": "total" }
          ]
        },
        {
          "title": "Event Loop Lag",
          "type": "timeseries",
          "datasource": { "uid": "${datasource}" },
          "gridPos": { "h": 8, "w": 8, "x": 8, "y": 66 },
          "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } },
          "targets": [
            { "expr": "nodejs_eventloop_lag_p50_seconds{app=\"tenno-api\"}", "legendFormat": "p50" },
            { "expr": "nodejs_eventloop_lag_p99_seconds{app=\"tenno-api\"}", "legendFormat": "p99" }
          ]
        },
        {
          "title": "Active Handles & Requests",
          "type": "timeseries",
          "datasource": { "uid": "${datasource}" },
          "gridPos": { "h": 8, "w": 8, "x": 16, "y": 66 },
          "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 15 } } },
          "targets": [
            { "expr": "nodejs_active_handles_total{app=\"tenno-api\"}", "legendFormat": "handles" },
            { "expr": "nodejs_active_requests_total{app=\"tenno-api\"}", "legendFormat": "requests" }
          ]
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
