{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "test:e2e:update-snapshots:docker": "docker run --rm -e CI=true -v \"$(pwd)/../..:/work\" -w /work/packages/web mcr.microsoft.com/playwright:v1.52.0-noble sh -c 'npm install -g pnpm && pnpm install --frozen-lockfile && pnpm test:e2e:update-snapshots'"
  },
  "dependencies": {
    "@warframe-tracker/shared": "workspace:*",
    "bootstrap": "^5.3.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.56.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "sass": "^1.98.0",
    "svelte": "^5.0.0",
    "typescript": "^6.0.2",
    "vite": "^6.0.0"
  }
}
